---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");

    return posts.map((post) => {
        const urlMatch = post.data.url.match(
            /\/(\d{4})\/(\d{2})\/(\d{2})\/([^/]+)\.html/,
        );
        const slug = urlMatch
            ? `${urlMatch[1]}/${urlMatch[2]}/${urlMatch[3]}/${urlMatch[4]}`
            : `blog/${post.slug}`;

        return {
            params: { slug },
            props: { post, slug },
        };
    });
}

const { post, slug } = Astro.props;
const { Content } = await post.render();
const date = post.data.date;

const plainText = post.body
    .replace(/<[^>]*>/g, "")
    .replace(/\n+/g, " ")
    .trim();

const displayTitle =
    post.data.title ||
    (plainText ? plainText.substring(0, 95) + "..." : "No content available");
---

<Layout title={`${displayTitle} — Eric Brookfield`} ogImage={`/og/${slug}.png`}>
    <article class="post">
        <div class="container">
            <header class="post-header">
                <a href="/" class="back-link">Back</a>
                <time class="post-date">
                    {
                        date.toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </time>
                <h1>{displayTitle}</h1>
            </header>
            <div class="post-content">
                <Content />
            </div>
            <footer class="post-footer">
                <a href="/">Home</a>
                <a href="/archive">Archive</a>
            </footer>
        </div>
    </article>
</Layout>

<style>
    .post {
        padding: var(--spacing-xl) 0;
        min-height: 100vh;
    }

    .container {
        max-width: 720px;
    }

    .post-header {
        margin-bottom: var(--spacing-lg);
    }

    .back-link {
        display: inline-block;
        margin-bottom: var(--spacing-md);
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-decoration: none;
        border-bottom: 1px solid var(--color-rule);
        padding-bottom: 1px;
    }

    .back-link:hover {
        color: var(--color-accent);
        border-color: var(--color-accent);
    }

    .post-date {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: var(--spacing-sm);
    }

    .post-header h1 {
        font-size: var(--text-h1);
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin-bottom: 0;
    }

    .post-content {
        font-size: clamp(1rem, 1.15vw, 1.0625rem);
        line-height: 1.75;
        margin-bottom: var(--spacing-xl);
    }

    :global(.post-content p) {
        margin-bottom: 1.5rem;
        color: var(--color-text-muted);
    }

    :global(.post-content p strong),
    :global(.post-content strong) {
        color: var(--color-text);
        font-weight: 600;
    }

    :global(.post-content em) {
        color: var(--color-text);
    }

    :global(.post-content h2) {
        font-size: clamp(1.375rem, 2.5vw, 1.75rem);
        margin-top: var(--spacing-lg);
        margin-bottom: var(--spacing-sm);
        letter-spacing: -0.02em;
    }

    :global(.post-content h2::after) {
        display: none;
    }

    :global(.post-content h3) {
        font-size: clamp(1.125rem, 1.8vw, 1.375rem);
        margin-top: var(--spacing-md);
        margin-bottom: var(--spacing-sm);
    }

    :global(.post-content a) {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    :global(.post-content a:hover) {
        color: var(--color-text);
    }

    :global(.post-content ul),
    :global(.post-content ol) {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
        color: var(--color-text-muted);
    }

    :global(.post-content li) {
        margin-bottom: 0.5rem;
    }

    :global(.post-content blockquote) {
        border-left: 3px solid var(--color-accent);
        padding-left: var(--spacing-md);
        margin: var(--spacing-md) 0;
        font-style: italic;
        color: var(--color-text-muted);
    }

    :global(.post-content code) {
        font-family: var(--font-mono);
        background: rgba(227, 222, 212, 0.06);
        padding: 0.15em 0.35em;
        font-size: 0.88em;
    }

    :global(.post-content pre) {
        background: rgba(227, 222, 212, 0.04);
        border: 1px solid var(--color-rule);
        padding: var(--spacing-md);
        overflow-x: auto;
        margin: var(--spacing-md) 0;
    }

    :global(.post-content pre code) {
        background: none;
        padding: 0;
        font-size: 0.875rem;
    }

    :global(.post-content img) {
        max-width: 100%;
        height: auto;
        margin: var(--spacing-md) 0;
        display: block;
    }

    :global(.post-content hr) {
        border: none;
        height: 1px;
        background: var(--color-rule);
        margin: var(--spacing-lg) 0;
    }

    .post-footer {
        display: flex;
        gap: var(--spacing-md);
        padding-top: var(--spacing-md);
        border-top: 1px solid var(--color-rule);
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .post-footer a {
        color: var(--color-text-muted);
        text-decoration: none;
    }

    .post-footer a:hover {
        color: var(--color-accent);
    }

    @media (max-width: 768px) {
        .post {
            padding: var(--spacing-lg) 0;
        }

        .post-header h1 {
            font-size: clamp(1.5rem, 5vw, 2rem);
        }
    }
</style>
