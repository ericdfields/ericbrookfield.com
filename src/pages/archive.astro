---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const postsByYear = posts
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .reduce(
        (acc, post) => {
            const year = post.data.date.getFullYear();
            if (!acc[year]) acc[year] = [];
            acc[year].push(post);
            return acc;
        },
        {} as Record<number, typeof posts>,
    );

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));

const urlPattern = /\/(\d{4})\/(\d{2})\/(\d{2})\/([^/]+)\.html/;
const stripMarkdown = (text: string) =>
    text
        .replace(/!\[([^\]]*)\]\([^)]+\)/g, "")
        .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
        .replace(/<[^>]*>/g, "")
        .replace(/(\*\*|__)(.*?)\1/g, "$2")
        .replace(/(\*|_)(.*?)\1/g, "$2")
        .replace(/`([^`]+)`/g, "$1")
        .replace(/^#{1,6}\s+/gm, "")
        .replace(/\n+/g, " ")
        .trim();

type ArchivePost = {
    formattedDate: string;
    localUrl: string;
    displayTitle: string;
};

const processedPostsByYear: Record<number, ArchivePost[]> = {};
for (const year of years) {
    processedPostsByYear[Number(year)] = postsByYear[Number(year)].map((post) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
        const urlMatch = post.data.url.match(urlPattern);
        const localUrl = urlMatch
            ? `/${urlMatch[1]}/${urlMatch[2]}/${urlMatch[3]}/${urlMatch[4]}`
            : `/blog/${post.slug}`;
        const plainText = stripMarkdown(post.body);
        const displayTitle = post.data.title || (plainText ? plainText.substring(0, 95) + "..." : "No content available");
        return { formattedDate, localUrl, displayTitle };
    });
}
---

<Layout title="Archive — Eric Brookfield">
    <main class="archive">
        <div class="container">
            <header class="archive-header">
                <a href="/" class="back-link">Back</a>
                <h1>ARCHIVE</h1>
                <p class="post-count">{posts.length} posts since {years[years.length - 1]}</p>
            </header>

            <div class="posts-by-year">
                {
                    years.map((year) => (
                        <section class="year-section">
                            <div class="year-label">{year}</div>
                            <div class="posts-list">
                                {processedPostsByYear[Number(year)].map((post) => (
                                    <a href={post.localUrl} class="archive-post">
                                        <span class="post-title">{post.displayTitle}</span>
                                        <span class="post-date">{post.formattedDate}</span>
                                    </a>
                                ))}
                            </div>
                        </section>
                    ))
                }
            </div>
        </div>
    </main>
</Layout>

<style>
    .archive {
        padding: var(--spacing-xl) 0;
        min-height: 100vh;
    }

    .container {
        max-width: 900px;
    }

    .archive-header {
        margin-bottom: var(--spacing-xl);
    }

    .back-link {
        display: inline-block;
        margin-bottom: var(--spacing-md);
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-decoration: none;
        border-bottom: 1px solid var(--color-rule);
        padding-bottom: 1px;
    }

    .back-link:hover {
        color: var(--color-accent);
        border-color: var(--color-accent);
    }

    .archive-header h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        letter-spacing: 0.04em;
        margin-bottom: 0.5rem;
    }

    .post-count {
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .year-section {
        display: grid;
        grid-template-columns: clamp(3.5rem, 6vw, 5rem) 1fr;
        gap: 2rem;
        margin-bottom: var(--spacing-lg);
    }

    .year-label {
        font-family: var(--font-display);
        font-size: clamp(1.25rem, 2vw, 1.75rem);
        font-weight: 700;
        color: var(--color-text);
        opacity: 0.3;
        line-height: 1;
        padding-top: 0.5rem;
    }

    .posts-list {
        display: flex;
        flex-direction: column;
    }

    .archive-post {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--color-rule);
        text-decoration: none;
    }

    .archive-post:last-child {
        border-bottom: none;
    }

    .archive-post:hover .post-title {
        color: var(--color-accent);
    }

    .post-title {
        color: var(--color-text);
        font-size: var(--text-body);
        line-height: 1.35;
        transition: color 0.15s ease;
    }

    .post-date {
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        color: var(--color-text-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }

    @media (max-width: 768px) {
        .year-section {
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }

        .archive-post {
            flex-direction: column;
            gap: 0.1rem;
        }
    }
</style>
