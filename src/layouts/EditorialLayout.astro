---
import Layout from "./Layout.astro";

export interface Props {
    title: string;
    description?: string;
    author?: string;
    date?: string;
    readingTime?: string;
    tags?: string[];
    chapterLabel?: string;
}

const {
    title,
    description,
    author = "Eric Brookfield",
    date,
    readingTime,
    tags = [],
    chapterLabel
} = Astro.props;

const formattedDate = date ? new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
}) : '';
---

<Layout title={title} description={description}>
    <main class="editorial-container">
        <article class="article-wrapper">
            <header class="article-header">
                {chapterLabel && (
                    <span class="chapter-label">{chapterLabel}</span>
                )}
                <h1>{title}</h1>
                {description && (
                    <p class="subheadline">{description}</p>
                )}
                <div class="byline">
                    <span>{author}</span>
                    {date && (
                        <>
                            <span class="sep">/</span>
                            <span>{formattedDate}</span>
                        </>
                    )}
                    {readingTime && (
                        <>
                            <span class="sep">/</span>
                            <span>{readingTime} min</span>
                        </>
                    )}
                </div>
            </header>

            <div class="article-content">
                <slot />
            </div>

            <footer class="article-footer">
                <a href="/">Home</a>
                <a href="/archive">Archive</a>
            </footer>
        </article>
    </main>
</Layout>

<style>
    .editorial-container {
        max-width: 720px;
        margin: 0 auto;
        padding: var(--spacing-xl) var(--spacing-md);
    }

    .chapter-label {
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-accent);
        display: block;
        margin-bottom: 1rem;
    }

    .article-header {
        margin-bottom: var(--spacing-lg);
        padding-bottom: var(--spacing-md);
        border-bottom: 1px solid var(--color-rule);
    }

    .article-header h1 {
        font-size: var(--text-h1);
        margin-bottom: 1rem;
    }

    .subheadline {
        font-size: var(--text-body);
        color: var(--color-text-muted);
        margin-bottom: 1rem;
    }

    .byline {
        display: flex;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .sep {
        color: var(--color-accent);
    }

    .article-content {
        font-size: clamp(1rem, 1.15vw, 1.0625rem);
        line-height: 1.75;
        color: var(--color-text-muted);
    }

    .article-content :global(p) {
        margin-bottom: 1.5rem;
    }

    .article-content :global(h2) {
        font-size: clamp(1.375rem, 2.5vw, 1.75rem);
        margin: var(--spacing-lg) 0 var(--spacing-sm);
        color: var(--color-text);
    }

    .article-content :global(h2::after) {
        display: none;
    }

    .article-content :global(h3) {
        font-size: clamp(1.125rem, 1.8vw, 1.375rem);
        margin: var(--spacing-md) 0 var(--spacing-sm);
        color: var(--color-text);
    }

    .article-content :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        padding-left: var(--spacing-md);
        margin: var(--spacing-md) 0;
        font-style: italic;
    }

    .article-content :global(code) {
        font-family: var(--font-mono);
        font-size: 0.88em;
        padding: 0.15em 0.35em;
        background: rgba(227, 222, 212, 0.06);
    }

    .article-content :global(pre) {
        background: rgba(227, 222, 212, 0.04);
        border: 1px solid var(--color-rule);
        padding: var(--spacing-md);
        overflow-x: auto;
        margin: var(--spacing-md) 0;
    }

    .article-content :global(pre code) {
        background: transparent;
        padding: 0;
        font-size: 0.875rem;
    }

    .article-content :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .article-content :global(strong) {
        color: var(--color-text);
        font-weight: 600;
    }

    .article-content :global(ul),
    .article-content :global(ol) {
        margin: 1.5rem 0;
        padding-left: 1.5rem;
    }

    .article-content :global(li) {
        margin-bottom: 0.5rem;
    }

    .article-content :global(img) {
        max-width: 100%;
        height: auto;
        margin: var(--spacing-md) 0;
        display: block;
    }

    .article-content :global(hr) {
        border: none;
        height: 1px;
        background: var(--color-rule);
        margin: var(--spacing-lg) 0;
    }

    .article-footer {
        display: flex;
        gap: var(--spacing-md);
        margin-top: var(--spacing-xl);
        padding-top: var(--spacing-md);
        border-top: 1px solid var(--color-rule);
        font-family: var(--font-mono);
        font-size: var(--text-mono);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .article-footer a {
        color: var(--color-text-muted);
        text-decoration: none;
    }

    .article-footer a:hover {
        color: var(--color-accent);
    }

    @media (max-width: 768px) {
        .editorial-container {
            padding: var(--spacing-lg) 1.25rem;
        }
    }
</style>
