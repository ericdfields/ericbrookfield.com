---
export interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
}

const {
    title = "Eric Brookfield",
    description = "Engineering director, product designer, builder of things.",
    ogImage,
} = Astro.props;

const siteUrl = "https://ericbrookfield.com";
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <title>{title}</title>

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl} />

        <!-- Fonts: Instrument Sans (display) + JetBrains Mono (metadata) -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />

        <link
            rel="alternate"
            type="application/rss+xml"
            title="Eric Brookfield - RSS Feed"
            href="/rss.xml"
        />
        <link
            rel="alternate"
            type="application/json"
            title="Eric Brookfield - JSON Feed"
            href="/feed.json"
        />
    </head>
    <body>
        <slot />
    </body>
</html>

<style is:global>
    :root {
        --max-width: 1200px;
        --spacing-xs: 0.5rem;
        --spacing-sm: 1rem;
        --spacing-md: 2rem;
        --spacing-lg: 3rem;
        --spacing-xl: 5rem;

        /* Colors — warm near-black, off-white, traffic cone orange */
        --color-bg: #110F0B;
        --color-text: #E3DED4;
        --color-text-muted: #8A8577;
        --color-accent: #FF5F1F;
        --color-rule: rgba(227, 222, 212, 0.12);
        --color-rule-heavy: rgba(227, 222, 212, 0.25);

        /* Type scale */
        --text-name: clamp(3.2rem, 14vw, 11rem);
        --text-h1: clamp(2rem, 5vw, 3.5rem);
        --text-h2: clamp(1.125rem, 1.5vw, 1.375rem);
        --text-body: clamp(0.9375rem, 1.1vw, 1.0625rem);
        --text-small: clamp(0.75rem, 0.9vw, 0.8125rem);
        --text-mono: clamp(0.6875rem, 0.85vw, 0.75rem);

        /* Font families */
        --font-display: 'Instrument Sans', -apple-system, sans-serif;
        --font-mono: 'JetBrains Mono', 'SF Mono', monospace;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html, body {
        margin: 0;
        width: 100%;
        min-height: 100%;
        font-family: var(--font-display);
        font-size: var(--text-body);
        color: var(--color-text);
        background-color: var(--color-bg);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    /* SVG grain overlay for analog warmth */
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.035;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 200px 200px;
        mix-blend-mode: overlay;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-display);
        line-height: 1.1;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: var(--color-text);
    }

    p {
        color: var(--color-text-muted);
        line-height: 1.65;
    }

    a {
        color: var(--color-text);
        text-decoration: none;
        transition: color 0.15s ease;
    }

    a:hover {
        color: var(--color-accent);
    }

    .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 var(--spacing-md);
    }

    @media (max-width: 768px) {
        .container {
            padding: 0 1.25rem;
        }
    }
</style>
